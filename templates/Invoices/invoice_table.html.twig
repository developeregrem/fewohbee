<table class="table table-bordered table-hover">
    <thead>
    <tr>
        <th>{{ 'invoice.number'|trans }}</th>
        <th>{{ 'invoice.date'|trans }}</th>
        <th>{{ 'invoice.lastname'|trans }}</th>
        <th>{{ 'invoice.company'|trans }}</th>
        <th>{{ 'invoice.status'|trans }}</th>
        <th>{{ 'invoice.action'|trans }}</th>
    </tr>
    </thead>
    <tbody>
    {% for invoice in invoices %}
        <tr>
            <td>{{ invoice.number }}</td>
            <td>{{ invoice.date|date('d.m.Y') }}</td>
            <td>{{ invoice.lastname }}</td>
            <td>{{ invoice.company }}</td>
            <td>
                {% if invoice.status == 1 %}
                    {{ 'invoice.status.unpaid'|trans }}
                {% elseif invoice.status == 2 %}
                    {{ 'invoice.status.paid'|trans }}
                {% elseif invoice.status == 3 %}
                    {{ 'invoice.status.prepaid'|trans }}
                {% else %}
                    {{ 'invoice.status.canceled'|trans }}
                {% endif %}
                {% if invoice.paymentMeans %}
                    {% set paymentMeansIcon = {
                        'CASH': 'fa-coins',
                        'CREDIT_TRANSFER': 'fa-building-columns',
                        'CARD_PAYMENT': 'fa-credit-card',
                        'SEPA_CREDIT_TRANSFER': 'fa-building-columns',
                        'SEPA_DIRECT_DEBIT': 'fa-money-check'
                    }[invoice.paymentMeans.name]|default('fa-circle-question') %}
                    <span class="ms-1 text-secondary"
                       title="{{ invoice.paymentMeans.name|trans }}"
                       aria-label="{{ invoice.paymentMeans.name|trans }}">
                        <i class="fa-solid {{ paymentMeansIcon }}" aria-hidden="true"></i>
                    </span>
                {% endif %}
            </td>
            <td>
                <a href="#" title="{{ 'button.details'|trans }}"
                   data-action="click->invoices#showInvoiceAction"
                   data-url="{{ path('invoices.get.invoice', {'id': invoice.id}) }}"
                   data-bs-toggle="modal" data-bs-target="#modalCenter">
                    <i class="fas fa-info-circle"></i></a>
                <a href="#" title="{{ 'button.edit'|trans }}"
                   data-action="click->invoices#showInvoiceAction"
                   data-edit="true"
                   data-url="{{ path('invoices.get.invoice', {'id': invoice.id}) }}"
                   data-bs-toggle="modal" data-bs-target="#modalCenter">
                    <i class="fas fa-edit"></i></a>
                <a class="export-link"
                   href="{{ path('invoices.export.pdf', {'id': invoice.id, 'template': templateId }) }}"
                   title="{{ 'button.export.pdf'|trans }}" target="_blank">
                    <i class="fas fa-file-pdf"></i></a>
                <a class="export-link"
                   href="{{ path('invoices.export.pdfxml', {'id': invoice.id, 'template': templateId }) }}"
                   title="{{ 'button.export.pdfxml'|trans }}" target="_blank">
                    <i class="fa-solid fa-file-invoice"></i></a>
                <a href="{{ path('invoices.export.xrechnung', {'id': invoice.id }) }}"
                    title="{{ 'button.export.xrechnung'|trans }}">
                     <i class="fa-solid fa-file-code"></i></a>
            </td>
        </tr>
    {% endfor %}
    </tbody>
</table>
<input id="page" type="hidden" name="page" value="{{ page }}" />
{% include 'paginator.html.twig' with { 'url' : path('invoices.overview') } %}
