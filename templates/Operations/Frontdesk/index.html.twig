{% extends 'base.html.twig' %}

{% block title %}{{ 'operations.frontdesk.title'|trans }}{% endblock %}

{% block content %}
<div class="container mt-4"
     data-controller="reservations housekeeping"
     data-reservations-translations-value="{{
        {
            'templates.select.reservations': 'templates.select.reservations'|trans,
            'nav.reservation.add': 'nav.reservation.add'|trans,
            'reservation.no.selected.appartments': 'reservation.no.selected.appartments'|trans,
            'reservation.details': 'reservation.details'|trans,
            'nav.reservation.edit': 'nav.reservation.edit'|trans,
            'templates.select.template': 'templates.select.template'|trans,
            'templates.edit': 'templates.edit'|trans,
            'templates.preview': 'templates.preview'|trans,
            'reservation.conflict.title': 'reservation.conflict.title'|trans
        }|json_encode|e('html_attr')
     }}">
    <div class="d-flex flex-wrap align-items-center gap-2 mb-3">
        <div class="me-auto">
            <h1 class="h3 mb-0">{{ 'operations.frontdesk.title'|trans }}</h1>
            <div class="text-muted small">
                {{ selectedDate|date('d.m.Y') }}
            </div>
        </div>
        <a href="#"
           class="btn btn-sm btn-outline-secondary shadow-none"
           data-action="click->housekeeping#submitFilters"
           title="{{ 'housekeeping.apply'|trans({}, 'Housekeeping') }}">
            <i class="fas fa-sync-alt" data-housekeeping-target="spinner" aria-hidden="true"></i>
        </a>
    </div>

    <form method="get" class="mb-3"
          data-housekeeping-target="form"
          data-action="change->housekeeping#submitFilters">
        <div class="row g-2 align-items-end">
            <div class="col col-md-3">
                <label class="form-label">{{ 'operations.frontdesk.filter.date'|trans }}</label>
                <input type="date" name="date" value="{{ selectedDate|date('Y-m-d') }}" class="form-control">
            </div>
            <div class="col-auto ms-auto">
                <button class="btn btn-outline-secondary shadow-none"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#frontdeskFilters"
                        aria-expanded="false"
                        aria-controls="frontdeskFilters">
                    <i class="fas fa-sliders-h" aria-hidden="true"></i>
                </button>
            </div>
        </div>
        <div class="collapse" id="frontdeskFilters">
            <div class="card card-body border mt-2 py-2 px-3">
                <div class="d-flex flex-wrap align-items-end gap-3">
                    <div style="min-width:180px">
                        <label class="form-label small mb-1">{{ 'operations.frontdesk.filter.subsidiary'|trans }}</label>
                        <select name="subsidiary" class="form-select form-select-sm">
                            <option value="all"{% if selectedSubsidiaryId == 'all' %} selected{% endif %}>
                                {{ 'housekeeping.subsidiary.all'|trans({}, 'Housekeeping') }}
                            </option>
                            {% for subsidiary in subsidiaries %}
                                <option value="{{ subsidiary.id }}"{% if selectedSubsidiaryId == subsidiary.id %} selected{% endif %}>
                                    {{ subsidiary.name }}
                                </option>
                            {% endfor %}
                        </select>
                    </div>
                    <div class="vr d-none d-md-block"></div>
                    <div class="d-flex flex-wrap gap-2">
                        <label class="form-check form-switch mb-0">
                            <input class="form-check-input" type="checkbox" name="categories[]"
                                   value="arrival"{% if 'arrival' in selectedCategories %} checked{% endif %}>
                            <span class="form-check-label small">{{ 'operations.frontdesk.arrivals'|trans }}</span>
                        </label>
                        <label class="form-check form-switch mb-0">
                            <input class="form-check-input" type="checkbox" name="categories[]"
                                   value="departure"{% if 'departure' in selectedCategories %} checked{% endif %}>
                            <span class="form-check-label small">{{ 'operations.frontdesk.departures'|trans }}</span>
                        </label>
                        <label class="form-check form-switch mb-0">
                            <input class="form-check-input" type="checkbox" name="categories[]"
                                   value="inhouse"{% if 'inhouse' in selectedCategories %} checked{% endif %}>
                            <span class="form-check-label small">{{ 'operations.frontdesk.inhouse'|trans }}</span>
                        </label>
                        <label class="form-check form-switch mb-0">
                            <input type="hidden" name="includeCanceled" value="0">
                            <input class="form-check-input" type="checkbox" name="includeCanceled" value="1"
                                {% if includeCanceled %}checked{% endif %}>
                            <span class="form-check-label small">{{ 'operations.frontdesk.filter.includeCanceled'|trans }}</span>
                        </label>
                    </div>
                </div>
            </div>
        </div>
    </form>

    <div data-housekeeping-target="content">
        {% include 'Operations/Frontdesk/_content.html.twig' %}
    </div>
</div>
{% endblock %}
