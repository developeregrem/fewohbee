{% extends 'base.html.twig' %}

{% block title %}{{ 'housekeeping.title'|trans({}, 'Housekeeping') }}{% endblock %}

{% block content %}
    <div class="container mt-4" data-controller="housekeeping">
        <div class="d-flex flex-wrap align-items-center gap-2 mb-3">
            <div class="me-auto">
                <h1 class="h3 mb-0">{{ 'housekeeping.title'|trans({}, 'Housekeeping') }}</h1>
                <div class="text-muted small">
                    {{ selectedDate|date('d.m.Y') }}
                </div>
            </div>
            <a href="#"
               class="btn btn-sm btn-outline-secondary shadow-none"
               data-action="click->housekeeping#submitFilters"
               title="{{ 'housekeeping.apply'|trans({}, 'Housekeeping') }}">
                <i class="fas fa-sync-alt" data-housekeeping-target="spinner" aria-hidden="true"></i>
            </a>
            <div class="btn-group" role="group">
                <a class="btn btn-outline-primary{% if view == 'day' %} active{% endif %}"
                   href="{{ path('operations.housekeeping', { date: selectedDate|date('Y-m-d'), subsidiary: selectedSubsidiaryId, view: 'day' }) }}">
                    {{ 'housekeeping.view.day'|trans({}, 'Housekeeping') }}
                </a>
                <a class="btn btn-outline-primary{% if view == 'week' %} active{% endif %}"
                   href="{{ path('operations.housekeeping', { date: selectedDate|date('Y-m-d'), subsidiary: selectedSubsidiaryId, view: 'week' }) }}">
                    {{ 'housekeeping.view.week'|trans({}, 'Housekeeping') }}
                </a>
            </div>
        </div>

        <form method="get" class="mb-3"
              data-housekeeping-target="form"
              data-action="change->housekeeping#submitFilters submit->housekeeping#spin">
            <div class="row g-2 align-items-end">
                <div class="col col-md-3">
                    <label class="form-label">{{ 'housekeeping.date'|trans({}, 'Housekeeping') }}</label>
                    <input type="date" name="date" value="{{ selectedDate|date('Y-m-d') }}" class="form-control">
                </div>
                <div class="col-auto ms-auto d-flex gap-2 flex-nowrap">
                    {% if view == 'day' %}
                        <a class="btn btn-outline-primary"
                           href="{{ path('operations.housekeeping.export', { date: selectedDate|date('Y-m-d'), subsidiary: selectedSubsidiaryId, range: 'day', occupancyTypes: selectedOccupancyTypes }) }}"
                           title="{{ 'housekeeping.export.day'|trans({}, 'Housekeeping') }}">
                            <i class="fas fa-file-csv" aria-hidden="true"></i>
                            <span class="visually-hidden">{{ 'housekeeping.export.day'|trans({}, 'Housekeeping') }}</span>
                        </a>
                    {% else %}
                        <a class="btn btn-outline-primary"
                           href="{{ path('operations.housekeeping.export', { date: selectedDate|date('Y-m-d'), subsidiary: selectedSubsidiaryId, range: 'week', occupancyTypes: selectedOccupancyTypes }) }}"
                           title="{{ 'housekeeping.export.week'|trans({}, 'Housekeeping') }}">
                            <i class="fas fa-file-csv" aria-hidden="true"></i>
                            <span class="visually-hidden">{{ 'housekeeping.export.week'|trans({}, 'Housekeeping') }}</span>
                        </a>
                    {% endif %}
                    <button class="btn btn-outline-secondary shadow-none"
                            type="button"
                            data-bs-toggle="collapse"
                            data-bs-target="#housekeepingFilters"
                            aria-expanded="false"
                            aria-controls="housekeepingFilters">
                        <i class="fas fa-sliders-h" aria-hidden="true"></i>
                    </button>
                </div>
            </div>
            <div class="collapse" id="housekeepingFilters">
                <div class="card card-body border mt-2 py-2 px-3">
                    <div class="d-flex flex-wrap align-items-end gap-3">
                        <div style="min-width:180px">
                            <label class="form-label small mb-1">{{ 'housekeeping.subsidiary'|trans({}, 'Housekeeping') }}</label>
                            <select name="subsidiary" class="form-select form-select-sm">
                                <option value="all"{% if selectedSubsidiaryId == 'all' %} selected{% endif %}>
                                    {{ 'housekeeping.subsidiary.all'|trans({}, 'Housekeeping') }}
                                </option>
                                {% for subsidiary in subsidiaries %}
                                    <option value="{{ subsidiary.id }}"{% if selectedSubsidiaryId == subsidiary.id %} selected{% endif %}>
                                        {{ subsidiary.name }}
                                    </option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="vr d-none d-md-block"></div>
                        <div class="d-flex flex-wrap gap-2">
                            {% for occType in occupancyTypes %}
                                <label class="form-check form-switch mb-0">
                                    <input class="form-check-input" type="checkbox" name="occupancyTypes[]"
                                           value="{{ occType }}"{% if occType in selectedOccupancyTypes %} checked{% endif %}>
                                    <span class="form-check-label small">
                                        {{ occupancyLabels[occType]|trans({}, 'Housekeeping') }}
                                    </span>
                                </label>
                            {% endfor %}
                        </div>
                    </div>
                </div>
            </div>
            <input type="hidden" name="view" value="{{ view }}">
        </form>

        <div data-housekeeping-target="content">
            {% include 'Operations/Housekeeping/_content.html.twig' %}
        </div>
    </div>
{% endblock %}
