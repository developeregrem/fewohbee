{% extends 'PublicBooking/base.html.twig' %}

{% block body %}
{% set autoScrollTarget = null %}
{% if step >= 3 and availability is not empty %}
    {% set autoScrollTarget = 'fhb-booker-details' %}
{% elseif availabilityChecked %}
    {% set autoScrollTarget = 'fhb-availability-results' %}
{% endif %}
<div class="fhb-booking-root">
    <div class="container{{ embed ? '-fluid' : '' }}">
        <div class="row justify-content-center">
            <div class="col-lg-8 col-xl-7">
                <div class="card fhb-booking-card">
                    <div class="card-body p-3 p-md-4">
                        <style>
                            .fhb-scroll-target {
                                scroll-margin-top: 1rem;
                            }
                        </style>
                        {% if not embed %}
                            <h2 class="mb-3 fs-4">{{ 'online_booking.public.page_title'|trans }}</h2>
                        {% endif %}

                        {# ── Step indicator ── #}
                        {% if not successMessage %}
                            {% set steps = [
                                'online_booking.public.step_search'|trans,
                                'online_booking.public.step_select'|trans,
                                'online_booking.public.step_details'|trans
                            ] %}
                            <div class="d-flex align-items-center gap-1 mb-3 small" aria-label="Progress">
                                {% for label in steps %}
                                    {% set stepNum = loop.index %}
                                    <span class="badge {{ step >= stepNum + 1 ? 'text-bg-primary' : 'text-bg-secondary' }} bg-opacity-{{ step >= stepNum + 1 ? '100' : '25' }}">{{ stepNum }}. {{ label }}</span>
                                    {% if not loop.last %}<span class="text-muted" style="font-size:.6rem">&#9654;</span>{% endif %}
                                {% endfor %}
                            </div>
                        {% endif %}

                        {% if errorMessage %}
                            <div class="alert alert-danger py-2">{{ errorMessage|trans }}</div>
                        {% endif %}

                        {% if successMessage %}
                            <div class="alert alert-success">{{ successMessage|trans }}</div>
                            {% if config.successMessageText %}
                                <div class="mb-3">{{ config.successMessageText|raw }}</div>
                            {% endif %}
                            <div class="mb-3">
                                <a class="btn btn-outline-primary btn-sm" href="{{ path('public.booking', {'embed': embed ? 1 : 0}) }}">
                                    {{ 'online_booking.public.start_new'|trans }}
                                </a>
                            </div>
                        {% endif %}

                        {% if not successMessage %}
                        <form method="post" action="{{ path('public.booking', {'embed': embed ? 1 : 0}) }}">
                            <input type="hidden" name="embed" value="{{ embed ? 1 : 0 }}">
                            <input type="hidden" name="form_started_at" value="{{ formState.formStartedAt }}">
                            {% if formState.submitToken %}
                                <input type="hidden" name="submit_token" value="{{ formState.submitToken }}">
                            {% endif %}
                            <div style="position:absolute;left:-9999px;top:auto;width:1px;height:1px;overflow:hidden;" aria-hidden="true">
                                <label for="website">{{ 'online_booking.public.website_field'|trans }}</label>
                                <input type="text" id="website" name="website" value="" tabindex="-1" autocomplete="off">
                            </div>

                            {# ── Step 1: Search ── #}
                            <div class="row g-2">
                                <div class="col-6 col-md-3">
                                    <label class="form-label small mb-1" for="dateFrom">{{ 'online_booking.public.arrival'|trans }}</label>
                                    <input class="form-control form-control-sm" type="date" id="dateFrom" name="dateFrom" min="{{ minArrivalDate }}" value="{{ search.dateFrom }}">
                                </div>
                                <div class="col-6 col-md-3">
                                    <label class="form-label small mb-1" for="dateTo">{{ 'online_booking.public.departure'|trans }}</label>
                                    <input class="form-control form-control-sm" type="date" id="dateTo" name="dateTo" min="{{ minArrivalDate }}" value="{{ search.dateTo }}">
                                </div>
                                <div class="col-6 col-md-3">
                                    <label class="form-label small mb-1" for="persons">{{ 'online_booking.public.persons'|trans }}</label>
                                    <input class="form-control form-control-sm" type="number" min="1" id="persons" name="persons" value="{{ search.persons|default(1) }}" onwheel="this.blur()">
                                </div>
                                <div class="col-6 col-md-3">
                                    <label class="form-label small mb-1" for="roomsCount">{{ 'online_booking.public.rooms'|trans }}</label>
                                    <input class="form-control form-control-sm" type="number" min="1" id="roomsCount" name="roomsCount" value="{{ search.roomsCount|default(1) }}" onwheel="this.blur()">
                                </div>
                            </div>

                            <div class="mt-3 text-end">
                                <button type="submit" name="intent" value="availability" class="btn btn-outline-primary btn-sm">{{ 'online_booking.public.check_availability'|trans }}</button>
                            </div>

                            {% if availabilityChecked and availability is empty and not errorMessage %}
                                <div class="alert alert-info mt-3 mb-0 py-2">
                                    {{ 'online_booking.public.no_matching_rooms'|trans }}
                                </div>
                            {% endif %}

                            {# ── Step 2: Room selection with occupancy options ── #}
                            {% if availability is not empty %}
                                <hr class="my-3 fhb-scroll-target" id="fhb-availability-results" tabindex="-1">
                                <h6 class="mb-2">{{ 'online_booking.public.available_room_types'|trans }}</h6>
                                {% for row in availability %}
                                    <div class="card mb-3">
                                        {# Hero image (primary image of this room category) #}
                                        {% if row.primaryImage is defined and row.primaryImage %}
                                            <img src="{{ app.request.basepath }}/{{ row.primaryImage.mediumUrl }}"
                                                 alt="{{ row.typeLabel }}"
                                                 class="card-img-top"
                                                 style="max-height:200px;object-fit:cover"
                                                 {% if row.images|length > 1 %}
                                                     role="button"
                                                     data-bs-toggle="modal"
                                                     data-bs-target="#gallery-{{ row.typeKey|replace({':': '-'}) }}"
                                                 {% endif %}>
                                        {% endif %}
                                        <div class="card-body py-2 px-3">
                                            <div class="d-flex justify-content-between align-items-start mb-1">
                                                <div>
                                                    <div class="fw-semibold">{{ row.typeLabel }}</div>
                                                    <small class="text-body-secondary">{{ 'online_booking.public.table.available'|trans }}: {{ row.availableCount }}</small>
                                                </div>
                                            </div>
                                            {% if row.typeDescription is not empty %}
                                                <div class="small text-body-secondary mb-2">{{ row.typeDescription }}</div>
                                            {% endif %}

                                            {# Amenity icons (max 6) + "+N" toggle to expand remaining #}
                                            {% if row.amenities is defined and row.amenities.items is not empty %}
                                                <div class="d-flex flex-wrap gap-2 mb-2 small text-body-secondary fhb-amenity-row align-items-center">
                                                    {% for amenity in row.amenities.items %}
                                                        <span title="{{ amenity.label }}"><i class="{{ amenity.iconClass }}"></i></span>
                                                    {% endfor %}
                                                    {% if row.amenities.remaining is not empty %}
                                                        {% for amenity in row.amenities.remaining %}
                                                            <span class="fhb-amenity-hidden" title="{{ amenity.label }}"><i class="{{ amenity.iconClass }}"></i></span>
                                                        {% endfor %}
                                                        <span class="fhb-amenity-more" role="button" tabindex="0"
                                                              onclick="this.parentNode.classList.add('fhb-amenity-expanded');this.remove()">
                                                            +{{ row.amenities.remaining|length }}
                                                        </span>
                                                    {% endif %}
                                                </div>
                                            {% endif %}

                                            {# Gallery link if multiple images exist #}
                                            {% if row.images is defined and row.images|length > 1 %}
                                                <a href="#" class="small text-body-secondary" data-bs-toggle="modal"
                                                   data-bs-target="#gallery-{{ row.typeKey|replace({':': '-'}) }}">
                                                    {{ 'online_booking.public.view_photos'|trans({'%count%': row.images|length}) }}
                                                </a>
                                            {% endif %}
                                            <div class="list-group list-group-flush">
                                                {% for option in row.occupancyOptions %}
                                                    {% set fieldName = 'occ_' ~ row.typeKey ~ '_p' ~ option.persons %}
                                                    {% set selectedVal = selectedQty[row.typeKey][option.persons]|default(0) %}
                                                    <div class="list-group-item px-0 py-2 d-flex align-items-center justify-content-between gap-2">
                                                        <div class="d-flex align-items-center gap-2 flex-grow-1">
                                                            <span title="{{ option.persons }} {{ option.persons == 1 ? ('online_booking.public.guest_singular'|trans) : ('online_booking.public.guest_plural'|trans) }}" style="letter-spacing:.1em">
                                                                {% for i in 1..option.persons %}👤{% endfor %}
                                                            </span>
                                                            <span class="fw-semibold ms-auto me-2">{{ option.totalPriceFormatted }}&nbsp;{{ currency_symbol }}</span>
                                                        </div>
                                                        <div style="width:70px;flex-shrink:0">
                                                            <input class="form-control form-control-sm text-center" type="number" min="0" max="{{ row.availableCount }}" name="{{ fieldName }}" value="{{ selectedVal }}" onwheel="this.blur()">
                                                        </div>
                                                    </div>
                                                {% endfor %}
                                            </div>
                                        </div>
                                    </div>
                                {% endfor %}

                                {# ── Extras (bookable miscellaneous prices) ── #}
                                {% if extras is not empty %}
                                    <div class="mt-3">
                                        <h6 class="mb-2">{{ 'online_booking.public.extras_title'|trans }}</h6>
                                        <div class="list-group">
                                            {% for extra in extras %}
                                                {% set extraFieldName = 'extra_' ~ extra.id %}
                                                {% set selectedQtyVal = selectedExtras[extra.id]|default(0) %}
                                                {% set needsQuantity = extra.calculationType != 'per_person_night' and extra.maxQuantity > 1 %}
                                                <div class="list-group-item d-flex align-items-center justify-content-between gap-2 py-2">
                                                    <div class="flex-grow-1">
                                                        <div class="fw-semibold small">{{ extra.description }}</div>
                                                        <div class="small text-body-secondary">
                                                            {{ extra.unitPriceFormatted }}&nbsp;{{ currency_symbol }}
                                                            {% if extra.calculationType == 'per_person_night' %}
                                                                {{ 'online_booking.public.per_person_night'|trans }}
                                                            {% elseif extra.calculationType == 'per_room_night' %}
                                                                {{ 'online_booking.public.per_room_night'|trans }}
                                                            {% else %}
                                                                {{ 'online_booking.public.flat_price'|trans }}
                                                            {% endif %}
                                                            <span class="ms-1 text-body-secondary">
                                                                (= {{ extra.pricePerUnitFormatted }}&nbsp;{{ currency_symbol }})
                                                            </span>
                                                        </div>
                                                    </div>
                                                    {% if needsQuantity %}
                                                        <div style="width:70px;flex-shrink:0">
                                                            <select class="form-select form-select-sm" name="{{ extraFieldName }}"
                                                                    onwheel="this.blur()">
                                                                <option value="0" {% if selectedQtyVal == 0 %}selected{% endif %}>–</option>
                                                                {% for q in 1..extra.maxQuantity %}
                                                                    <option value="{{ q }}" {% if selectedQtyVal == q %}selected{% endif %}>{{ q }}</option>
                                                                {% endfor %}
                                                            </select>
                                                        </div>
                                                    {% else %}
                                                        <div class="form-check form-switch mb-0 ms-2">
                                                            <input class="form-check-input" type="checkbox" role="switch"
                                                                   id="{{ extraFieldName }}" name="{{ extraFieldName }}" value="1"
                                                                   {% if selectedQtyVal > 0 %}checked{% endif %}>
                                                        </div>
                                                    {% endif %}
                                                </div>
                                            {% endfor %}
                                        </div>
                                    </div>
                                {% endif %}

                                <div class="mt-3 text-end">
                                    <button type="submit" name="intent" value="preview" class="btn btn-primary btn-sm">{{ 'online_booking.public.continue'|trans }}</button>
                                </div>

                                {# Image gallery modals (Bootstrap carousel lightbox) #}
                                {% for row in availability %}
                                    {% if row.images is defined and row.images|length > 1 %}
                                        <div class="modal fade" id="gallery-{{ row.typeKey|replace({':': '-'}) }}" tabindex="-1">
                                            <div class="modal-dialog modal-lg modal-dialog-centered">
                                                <div class="modal-content">
                                                    <div class="modal-header py-2">
                                                        <h6 class="modal-title">{{ row.typeLabel }}</h6>
                                                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                                    </div>
                                                    <div class="modal-body p-0">
                                                        <div id="carousel-{{ row.typeKey|replace({':': '-'}) }}" class="carousel slide">
                                                            <div class="carousel-inner">
                                                                {% for img in row.images %}
                                                                    <div class="carousel-item {{ loop.first ? 'active' : '' }}">
                                                                        <img src="{{ app.request.basepath }}/{{ img.mediumUrl }}" class="d-block w-100" alt="">
                                                                    </div>
                                                                {% endfor %}
                                                            </div>
                                                            {% if row.images|length > 1 %}
                                                                <button class="carousel-control-prev" type="button"
                                                                        data-bs-target="#carousel-{{ row.typeKey|replace({':': '-'}) }}" data-bs-slide="prev">
                                                                    <span class="carousel-control-prev-icon"></span>
                                                                </button>
                                                                <button class="carousel-control-next" type="button"
                                                                        data-bs-target="#carousel-{{ row.typeKey|replace({':': '-'}) }}" data-bs-slide="next">
                                                                    <span class="carousel-control-next-icon"></span>
                                                                </button>
                                                            {% endif %}
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    {% endif %}
                                {% endfor %}
                            {% endif %}

                            {# ── Step 3: Booker details + summary ── #}
                            {% if step >= 3 and availability is not empty %}
                                {# No hidden fields needed for occ_/extra_ — the visible Step 2
                                   inputs are still in the DOM and carry the current values.
                                   Duplicating them as hidden fields would override user changes. #}
                                <hr class="my-3 fhb-scroll-target" id="fhb-booker-details" tabindex="-1">
                                <h6 class="mb-2">{{ 'online_booking.public.booker_details'|trans }}</h6>

                                {# Row 1: Salutation / First name / Last name #}
                                <div class="row g-2 mb-2">
                                    <div class="col-12 col-md-3">
                                        <label class="form-label small mb-1" for="salutation">{{ 'customer.salutation'|trans }}</label>
                                        <select class="form-select form-select-sm" id="salutation" name="salutation" required>
                                            <option value="">--</option>
                                            {% for salutation in customer_salutations %}
                                                {% set translatedSalutation = salutation|trans %}
                                                <option value="{{ translatedSalutation }}" {% if booker.salutation == translatedSalutation %}selected{% endif %}>{{ translatedSalutation }}</option>
                                            {% endfor %}
                                        </select>
                                    </div>
                                    <div class="col-6 col-md">
                                        <label class="form-label small mb-1" for="firstname">{{ 'customer.firstname'|trans }}</label>
                                        <input class="form-control form-control-sm" type="text" id="firstname" name="firstname" required value="{{ booker.firstname }}">
                                    </div>
                                    <div class="col-6 col-md">
                                        <label class="form-label small mb-1" for="lastname">{{ 'customer.lastname'|trans }}</label>
                                        <input class="form-control form-control-sm" type="text" id="lastname" name="lastname" required value="{{ booker.lastname }}">
                                    </div>
                                </div>

                                {# Row 2: Email / Phone / Company #}
                                <div class="row g-2 mb-2">
                                    <div class="col-12 col-md-4">
                                        <label class="form-label small mb-1" for="email">{{ 'online_booking.public.email'|trans }}</label>
                                        <input class="form-control form-control-sm" type="email" id="email" name="email" required value="{{ booker.email }}">
                                    </div>
                                    <div class="col-6 col-md-4">
                                        <label class="form-label small mb-1" for="phone">{{ 'online_booking.public.phone'|trans }}</label>
                                        <input class="form-control form-control-sm" type="tel" id="phone" name="phone" value="{{ booker.phone }}">
                                    </div>
                                    <div class="col-6 col-md-4">
                                        <label class="form-label small mb-1" for="company">{{ 'customer.company'|trans }}</label>
                                        <input class="form-control form-control-sm" type="text" id="company" name="company" value="{{ booker.company }}">
                                    </div>
                                </div>

                                {# Row 3: Street / Zip / City / Country #}
                                <div class="row g-2 mb-2">
                                    <div class="col-12 col-md-5">
                                        <label class="form-label small mb-1" for="address">{{ 'customer.address'|trans }}</label>
                                        <input class="form-control form-control-sm" type="text" id="address" name="address" required value="{{ booker.address }}">
                                    </div>
                                    <div class="col-4 col-md-2">
                                        <label class="form-label small mb-1" for="zip">{{ 'customer.zip'|trans }}</label>
                                        <input class="form-control form-control-sm" type="text" id="zip" name="zip" required value="{{ booker.zip }}">
                                    </div>
                                    <div class="col-8 col-md-3">
                                        <label class="form-label small mb-1" for="city">{{ 'customer.city'|trans }}</label>
                                        <input class="form-control form-control-sm" type="text" id="city" name="city" required value="{{ booker.city }}">
                                    </div>
                                    <div class="col-12 col-md-2">
                                        <label class="form-label small mb-1" for="country">{{ 'customer.country'|trans }}</label>
                                        <select class="form-select form-select-sm" id="country" name="country" required>
                                            {% for key, country in countries %}
                                                <option value="{{ key }}" {% if booker.country == key %}selected{% endif %}>{{ country }}</option>
                                            {% endfor %}
                                        </select>
                                    </div>
                                </div>

                                {# Row 4: Comment #}
                                <div class="row g-2">
                                    <div class="col-12">
                                        <label class="form-label small mb-1" for="comment">{{ 'online_booking.public.comment'|trans }}</label>
                                        <textarea class="form-control form-control-sm" id="comment" name="comment" rows="2">{{ booker.comment }}</textarea>
                                    </div>
                                </div>

                                {# ── Summary ── #}
                                <div class="fhb-booking-summary mt-3">
                                    <div class="small text-body-secondary mb-1">{{ 'online_booking.public.summary_title'|trans }}</div>
                                    <div class="small mb-1">
                                        <strong>{{ 'online_booking.public.arrival'|trans }}:</strong> {{ search.dateFrom }}
                                        <span class="mx-1">|</span>
                                        <strong>{{ 'online_booking.public.departure'|trans }}:</strong> {{ search.dateTo }}
                                        <span class="mx-1">|</span>
                                        <strong>{{ 'online_booking.public.persons'|trans }}:</strong> {{ search.persons }}
                                        <span class="mx-1">|</span>
                                        <strong>{{ 'online_booking.public.rooms'|trans }}:</strong> {{ search.roomsCount }}
                                    </div>
                                    <div class="small">
                                        {% set renderedSelection = false %}
                                        {% for row in availability %}
                                            {% set typeSelection = selectedQty[row.typeKey]|default({}) %}
                                            {% for persons, qty in typeSelection %}
                                                {% if qty > 0 %}
                                                    {% if renderedSelection %}, {% endif %}
                                                    {{ qty }}x {{ row.typeLabel }} ({{ persons }} {{ persons == 1 ? ('online_booking.public.guest_singular'|trans) : ('online_booking.public.guest_plural'|trans) }})
                                                    {% set renderedSelection = true %}
                                                {% endif %}
                                            {% endfor %}
                                        {% endfor %}
                                    </div>
                                </div>

                                {% if roomTotalFormatted %}
                                    <div class="fhb-booking-summary mt-2">
                                        {% if roomPriceBreakdown is not empty %}
                                            <div class="mb-2">
                                                {% for priceRow in roomPriceBreakdown %}
                                                    <div class="d-flex justify-content-between align-items-center small{% if not loop.last %} mb-1{% endif %}">
                                                        <span>{{ priceRow.label }}{% if priceRow.quantity > 1 %} ({{ priceRow.quantity }}x){% endif %}</span>
                                                        <span>{{ priceRow.totalFormatted }} {{ currency_symbol }}</span>
                                                    </div>
                                                {% endfor %}
                                            </div>
                                        {% endif %}

                                        {# Extras breakdown #}
                                        {% if extrasBreakdown is not empty %}
                                            <div class="mb-2">
                                                {% for extraRow in extrasBreakdown %}
                                                    <div class="d-flex justify-content-between align-items-center small{% if not loop.last %} mb-1{% endif %}">
                                                        <span>{{ extraRow.label }}{% if extraRow.quantity|default(1) > 1 %} &times; {{ extraRow.quantity }}{% endif %}</span>
                                                        <span>{{ extraRow.totalFormatted }} {{ currency_symbol }}</span>
                                                    </div>
                                                {% endfor %}
                                            </div>
                                        {% endif %}

                                        {% if grandTotalFormatted and extrasBreakdown is not empty %}
                                            <div class="d-flex justify-content-between align-items-center small text-body-secondary mb-1">
                                                <span>{{ 'online_booking.public.room_total'|trans }}</span>
                                                <span>{{ roomTotalFormatted }} {{ currency_symbol }}</span>
                                            </div>
                                            <div class="d-flex justify-content-between align-items-center small text-body-secondary mb-2">
                                                <span>{{ 'online_booking.public.extras_total'|trans }}</span>
                                                <span>{{ extrasTotalFormatted }} {{ currency_symbol }}</span>
                                            </div>
                                            <div class="d-flex justify-content-between align-items-center border-top pt-2">
                                                <span>{{ 'online_booking.public.grand_total'|trans }}</span>
                                                <strong class="text-primary">{{ grandTotalFormatted }} {{ currency_symbol }}</strong>
                                            </div>
                                        {% else %}
                                            <div class="d-flex justify-content-between align-items-center">
                                                <span>{{ 'online_booking.public.room_total'|trans }}</span>
                                                <strong class="text-primary">{{ roomTotalFormatted }} {{ currency_symbol }}</strong>
                                            </div>
                                            <div class="small text-body-secondary">{{ 'online_booking.public.room_total_hint'|trans }}</div>
                                        {% endif %}
                                    </div>
                                {% endif %}

                                {% if config.paymentTerms %}
                                    <div class="fhb-booking-summary mt-2">
                                        <div class="small text-body-secondary mb-1">{{ 'online_booking.public.payment_terms'|trans }}</div>
                                        <div class="small">{{ config.paymentTerms|raw }}</div>
                                    </div>
                                {% endif %}

                                {% if config.cancellationTerms %}
                                    <div class="fhb-booking-summary mt-2">
                                        <div class="small text-body-secondary mb-1">{{ 'online_booking.public.cancellation_terms'|trans }}</div>
                                        <div class="small">{{ config.cancellationTerms|raw }}</div>
                                    </div>
                                {% endif %}

                                <div class="mt-3 text-end">
                                    <button type="submit" name="intent" value="submit" class="btn btn-primary">
                                        {{ config.bookingMode == 'BOOKING' ? ('online_booking.public.submit_booking'|trans) : ('online_booking.public.submit_inquiry'|trans) }}
                                    </button>
                                </div>
                            {% endif %}
                        </form>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% if autoScrollTarget %}
<script>
(function() {
    var targetId = {{ autoScrollTarget|json_encode|raw }};
    function jumpToStep() {
        var target = document.getElementById(targetId);
        if (!target) {
            return;
        }

        target.scrollIntoView({ block: 'start', behavior: 'auto' });
        if (typeof target.focus === 'function') {
            target.focus({ preventScroll: true });
        }
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', function() {
            requestAnimationFrame(jumpToStep);
        }, { once: true });
    } else {
        requestAnimationFrame(jumpToStep);
    }
})();
</script>
{% endif %}
{% endblock %}
