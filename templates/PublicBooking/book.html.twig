{% extends 'PublicBooking/base.html.twig' %}

{% block body %}
<div class="fhb-booking-root">
    <div class="container{{ embed ? '-fluid' : '' }}">
        <div class="row justify-content-center">
            <div class="col-lg-9">
                <div class="card fhb-booking-card">
                    <div class="card-body p-4">
                        {% if not embed %}
                            <h2 class="mb-3">{{ 'online_booking.public.page_title'|trans }}</h2>
                        {% endif %}

                        {% if errorMessage %}
                            <div class="alert alert-danger">{{ errorMessage|trans }}</div>
                        {% endif %}

                        {% if successMessage %}
                            <div class="alert alert-success">{{ successMessage|trans }}</div>
                            {% if config.successMessageText %}
                                <div class="mb-3">{{ config.successMessageText|raw }}</div>
                            {% endif %}
                            <div class="mb-3">
                                <a class="btn btn-outline-primary btn-sm" href="{{ path('public.booking', {'embed': embed ? 1 : 0}) }}">
                                    {{ 'online_booking.public.start_new'|trans }}
                                </a>
                            </div>
                        {% endif %}

                        {% if not successMessage %}
                        <form method="post" action="{{ path('public.booking', {'embed': embed ? 1 : 0}) }}">
                            <input type="hidden" name="embed" value="{{ embed ? 1 : 0 }}">
                            <input type="hidden" name="form_started_at" value="{{ formState.formStartedAt }}">
                            {% if formState.submitToken %}
                                <input type="hidden" name="submit_token" value="{{ formState.submitToken }}">
                            {% endif %}
                            <div style="position:absolute;left:-9999px;top:auto;width:1px;height:1px;overflow:hidden;" aria-hidden="true">
                                <label for="website">{{ 'online_booking.public.website_field'|trans }}</label>
                                <input type="text" id="website" name="website" value="" tabindex="-1" autocomplete="off">
                            </div>

                            <div class="row">
                                <div class="col-md-3">
                                    <label class="form-label" for="dateFrom">{{ 'online_booking.public.arrival'|trans }}</label>
                                    <input class="form-control" type="date" id="dateFrom" name="dateFrom" min="{{ minArrivalDate }}" value="{{ search.dateFrom }}">
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label" for="dateTo">{{ 'online_booking.public.departure'|trans }}</label>
                                    <input class="form-control" type="date" id="dateTo" name="dateTo" min="{{ minArrivalDate }}" value="{{ search.dateTo }}">
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label" for="persons">{{ 'online_booking.public.persons'|trans }}</label>
                                    <input class="form-control" type="number" min="1" id="persons" name="persons" value="{{ search.persons|default(1) }}">
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label" for="roomsCount">{{ 'online_booking.public.rooms'|trans }}</label>
                                    <input class="form-control" type="number" min="1" id="roomsCount" name="roomsCount" value="{{ search.roomsCount|default(1) }}">
                                </div>
                            </div>

                            <div class="mt-3">
                                <button type="submit" name="intent" value="availability" class="btn btn-outline-primary">{{ 'online_booking.public.check_availability'|trans }}</button>
                            </div>

                            {% if availabilityChecked and availability is empty and not errorMessage %}
                                <div class="alert alert-info mt-4 mb-0">
                                    {{ 'online_booking.public.no_matching_rooms'|trans }}
                                </div>
                            {% endif %}

                            {% if availability is not empty %}
                                <hr class="my-4">
                                <h5 class="mb-3">{{ 'online_booking.public.available_room_types'|trans }}</h5>
                                <div class="table-responsive">
                                    <table class="table table-sm align-middle">
                                        <thead>
                                            <tr>
                                                <th>{{ 'online_booking.public.table.type'|trans }}</th>
                                                <th>{{ 'online_booking.public.table.max_guests'|trans }}</th>
                                                <th>{{ 'online_booking.public.table.available'|trans }}</th>
                                                <th style="width: 150px;">{{ 'online_booking.public.table.qty'|trans }}</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                        {% for row in availability %}
                                            {% set fieldName = 'qty_' ~ row.typeKey %}
                                            <tr>
                                                <td>
                                                    <div class="fw-semibold">{{ row.typeLabel }}</div>
                                                    {% if row.typeDescription is not empty %}
                                                        <div class="small text-muted">{{ row.typeDescription }}</div>
                                                    {% endif %}
                                                </td>
                                                <td>{{ row.maxGuests }}</td>
                                                <td>{{ row.availableCount }}</td>
                                                <td>
                                                    <input
                                                        class="form-control"
                                                        type="number"
                                                        min="0"
                                                        max="{{ row.availableCount }}"
                                                        name="{{ fieldName }}"
                                                        value="{{ selectedQty[row.typeKey]|default(0) }}"
                                                    >
                                                </td>
                                            </tr>
                                        {% endfor %}
                                        </tbody>
                                    </table>
                                </div>

                                <div class="d-flex gap-2 mb-3">
                                    <button type="submit" name="intent" value="preview" class="btn btn-primary">{{ 'online_booking.public.continue'|trans }}</button>
                                </div>
                            {% endif %}

                            {% if step >= 3 and availability is not empty %}
                                <hr class="my-4">
                                <h5 class="mb-3">{{ 'online_booking.public.booker_details'|trans }}</h5>
                                <div class="border rounded-3 p-3 bg-body-tertiary">
                                    <div class="small text-muted text-uppercase mb-3">{{ 'online_booking.public.booker_details'|trans }}</div>
                                    <div class="row g-3">
                                        <div class="col-md-3">
                                            <label class="form-label" for="salutation">{{ 'customer.salutation'|trans }}</label>
                                            <select class="form-select" id="salutation" name="salutation" required>
                                                <option value="">{{ 'online_booking.public.select_salutation'|trans }}</option>
                                                {% for salutation in customer_salutations %}
                                                    {% set translatedSalutation = salutation|trans %}
                                                    <option value="{{ translatedSalutation }}" {% if booker.salutation == translatedSalutation %}selected{% endif %}>{{ translatedSalutation }}</option>
                                                {% endfor %}
                                            </select>
                                        </div>
                                        <div class="col-md-4">
                                            <label class="form-label" for="firstname">{{ 'customer.firstname'|trans }}</label>
                                            <input class="form-control" type="text" id="firstname" name="firstname" required value="{{ booker.firstname }}">
                                        </div>
                                        <div class="col-md-5">
                                            <label class="form-label" for="lastname">{{ 'customer.lastname'|trans }}</label>
                                            <input class="form-control" type="text" id="lastname" name="lastname" required value="{{ booker.lastname }}">
                                        </div>
                                        <div class="col-md-7">
                                            <label class="form-label" for="email">{{ 'online_booking.public.email'|trans }}</label>
                                            <input class="form-control" type="email" id="email" name="email" required value="{{ booker.email }}">
                                        </div>
                                        <div class="col-md-5">
                                            <label class="form-label" for="phone">{{ 'online_booking.public.phone'|trans }}</label>
                                            <input class="form-control" type="tel" id="phone" name="phone" value="{{ booker.phone }}">
                                        </div>
                                        <div class="col-12">
                                            <label class="form-label" for="company">{{ 'customer.company'|trans }}</label>
                                            <input class="form-control" type="text" id="company" name="company" value="{{ booker.company }}">
                                        </div>
                                        <div class="col-12">
                                            <label class="form-label" for="address">{{ 'customer.address'|trans }}</label>
                                            <input class="form-control" type="text" id="address" name="address" required value="{{ booker.address }}">
                                        </div>
                                        <div class="col-md-3">
                                            <label class="form-label" for="zip">{{ 'customer.zip'|trans }}</label>
                                            <input class="form-control" type="text" id="zip" name="zip" required value="{{ booker.zip }}">
                                        </div>
                                        <div class="col-md-5">
                                            <label class="form-label" for="city">{{ 'customer.city'|trans }}</label>
                                            <input class="form-control" type="text" id="city" name="city" required value="{{ booker.city }}">
                                        </div>
                                        <div class="col-md-4">
                                            <label class="form-label" for="country">{{ 'customer.country'|trans }}</label>
                                            <select class="form-select" id="country" name="country" required>
                                                {% for country in countries %}
                                                    <option value="{{ country }}" {% if booker.country == country %}selected{% endif %}>{{ country }}</option>
                                                {% endfor %}
                                            </select>
                                        </div>
                                    </div>
                                </div>

                                <div class="mt-3">
                                    <label class="form-label" for="comment">{{ 'online_booking.public.comment'|trans }}</label>
                                    <textarea class="form-control" id="comment" name="comment" rows="4">{{ booker.comment }}</textarea>
                                </div>

                                <div class="fhb-booking-summary mt-3">
                                    <div class="small text-muted mb-2">{{ 'online_booking.public.summary_title'|trans }}</div>
                                    <div class="mb-1">
                                        <strong>{{ 'online_booking.public.arrival'|trans }}:</strong> {{ search.dateFrom }}
                                        <span class="mx-2">|</span>
                                        <strong>{{ 'online_booking.public.departure'|trans }}:</strong> {{ search.dateTo }}
                                    </div>
                                    <div class="mb-1">
                                        <strong>{{ 'online_booking.public.persons'|trans }}:</strong> {{ search.persons }}
                                        <span class="mx-2">|</span>
                                        <strong>{{ 'online_booking.public.rooms'|trans }}:</strong> {{ search.roomsCount }}
                                    </div>
                                    <div>
                                        <strong>{{ 'online_booking.public.selected_categories'|trans }}:</strong>
                                        {% set renderedSelection = false %}
                                        {% for row in availability %}
                                            {% if selectedQty[row.typeKey]|default(0) > 0 %}
                                                {% if renderedSelection %}, {% endif %}
                                                {{ selectedQty[row.typeKey] }}x {{ row.typeLabel }}
                                                {% set renderedSelection = true %}
                                            {% endif %}
                                        {% endfor %}
                                    </div>
                                </div>

                                {% if roomTotalFormatted %}
                                    <div class="fhb-booking-summary mt-3">
                                        {% if roomPriceBreakdown is not empty %}
                                            <div class="mb-3">
                                                {% for priceRow in roomPriceBreakdown %}
                                                    <div class="d-flex justify-content-between align-items-center{% if not loop.last %} mb-1{% endif %}">
                                                        <span>{{ priceRow.label }}{% if priceRow.quantity > 1 %} ({{ priceRow.quantity }}x){% endif %}</span>
                                                        <span>{{ priceRow.totalFormatted }} €</span>
                                                    </div>
                                                {% endfor %}
                                            </div>
                                        {% endif %}
                                        <div class="d-flex justify-content-between align-items-center">
                                            <span>{{ 'online_booking.public.room_total'|trans }}</span>
                                            <strong class="text-primary">{{ roomTotalFormatted }} €</strong>
                                        </div>
                                        <div class="small text-muted">{{ 'online_booking.public.room_total_hint'|trans }}</div>
                                    </div>
                                {% endif %}

                                {% if config.paymentTerms %}
                                    <div class="fhb-booking-summary mt-3">
                                        <div class="small text-muted mb-2">{{ 'online_booking.public.payment_terms'|trans }}</div>
                                        <div>{{ config.paymentTerms|raw }}</div>
                                    </div>
                                {% endif %}

                                {% if config.cancellationTerms %}
                                    <div class="fhb-booking-summary mt-3">
                                        <div class="small text-muted mb-2">{{ 'online_booking.public.cancellation_terms'|trans }}</div>
                                        <div>{{ config.cancellationTerms|raw }}</div>
                                    </div>
                                {% endif %}

                                <div class="mt-3">
                                    <button type="submit" name="intent" value="submit" class="btn btn-primary">
                                        {{ config.bookingMode == 'BOOKING' ? ('online_booking.public.submit_booking'|trans) : ('online_booking.public.submit_inquiry'|trans) }}
                                    </button>
                                </div>
                            {% endif %}
                        </form>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
