{% if error is not defined or error %}    
    {% for type, flashMessages in app.flashes %}
        {% for flashMessage in flashMessages %}
        <div class="row">
            <div class="col-md">
                <div class="alert alert-{{ type }} alert-dismissible fade show" role="alert">
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    {{ flashMessage|trans }}
                </div>
            </div>
        </div>
        {% endfor %}
    {% endfor %}    
    {% if attachment is defined %}
    {# marker for JS to detect that this saved file is a mail attachment #}
    <span class="d-none" data-is-attachment="true"></span>
    {% endif %}
{% endif %}