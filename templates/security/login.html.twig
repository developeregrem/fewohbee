{% extends 'base.html.twig' %}

{% block title %}{{ parent() }} -  {{ 'login.title'|trans }}{% endblock %}

{% block description %}{{ parent() }} -  {{ 'login.description'|trans }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ app.request.basepath }}/resources/css/signin.css">
{% endblock %}

{% block javascripts %}
    {{ parent() }}
{% endblock %}

{% block body %}
<main class="form-signin text-center" {{ stimulus_controller('login', { startUrl: path('dashboard.redirect') }) }}>
  <form action="{{ path('login') }}" method="post" data-turbo="false"
  {% if passkey_enabled %}
  {{ stimulus_controller('webauthn',
        {
            conditionalUi: true,
            successRedirectUri: path('dashboard.redirect'),
            resultUrl: path('webauthn_authentication_verify'),
            optionsUrl: path('webauthn_authentication_options')
        }
    ) }}
    {% endif %}
    >
    <div class="logo-icon-stack mb-4"><img src="{{ app.request.basepath }}/img/logo-fewohbee.png"></div>
    <h1 class="h3 mb-3 fw-normal"><span style="color: #012546">Fewoh</span><span style="color: #FB9005">Bee</span></h1>

    {% if error %}
        <div class="alert alert-danger">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
    {% endif %}
    <div id="login-error" data-login-target="error" class="alert alert-danger mt-3 d-none alert-dismissible" role="alert">
        {{ 'login.webauthn.failure'|trans }}
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
    <div class="form-floating">
      <input type="text" class="form-control" id="floatingInput" name="_username" placeholder="{{ 'login.username.placeholder'|trans }}" {% if passkey_enabled %}data-webauthn-target="username"{% endif %}>
      <label for="floatingInput">{{ 'login.username.placeholder'|trans }}</label>
    </div>
    <div class="form-floating">
      <input type="password" class="form-control" id="floatingPassword" name="_password"  placeholder="{{ 'login.password.placeholder'|trans }}">
      <label for="floatingPassword">{{ 'login.password.placeholder'|trans }}</label>
    </div>
    <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

    <div class="checkbox mb-3">
      <label>
        <input type="checkbox" name="_remember_me"> {{ 'login.rememberme'|trans }}
      </label>
    </div>
    <button class="w-100 btn btn-lg btn-primary" type="submit">{{ 'login.submit.value'|trans }}</button>
    {% if passkey_enabled %}
    <button class="w-100 btn btn-lg btn-secondary mt-2"
        {{ stimulus_action('webauthn', 'authenticate') }}>
            <i class="fas fa-key"></i> {{ 'login.passkey'|trans }}
        </button>
    {% endif %}
    <div class="row mt-3">
        <div class="col text-end"><a href="{{ path('app_forgot_password_request') }}">{{ 'login.pwforgotten.link'|trans }}</a></div>
    </div>
    <p class="mt-4 mb-3 text-muted">&copy; Copyright {{ "now"|date("Y") }} - <a class="text-muted" href="https://www.fewohbee.app" target="_blank" style="text-decoration:none;" onmouseover="this.style.textDecoration='underline';" onmouseout="this.style.textDecoration='none';">{{ 'login.copy'|trans }}</a></p>
  </form>
</main>
{% endblock %}
