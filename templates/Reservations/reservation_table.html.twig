{% set displayMonth = true %}
{% set displayWeek = true %}
{% set displayWeekday = true %}

{% set weekdayLabels = {
    1: 'reservation.table.weekday.monday'|trans,
    2: 'reservation.table.weekday.tuesday'|trans,
    3: 'reservation.table.weekday.wednesday'|trans,
    4: 'reservation.table.weekday.thursday'|trans,
    5: 'reservation.table.weekday.friday'|trans,
    6: 'reservation.table.weekday.saturday'|trans,
    7: 'reservation.table.weekday.sunday'|trans,
} %}

{% if selectedSubdivision == 'all' %}
    {% set showCountry = holidayCountry %}
{% else %}
    {% set showCountry = selectedSubdivision %}
{% endif %}

{% use 'Reservations/_resevation_popover.html.twig' %}

<div class="table-responsive js-fit-vh" data-min-height="200">
    <table class="table table-hover table-bordered table-reservation m-0 table-sticky mb-2" id="reservation-table">
        <thead>
        {# ── Month headers ── #}
        {% if displayMonth %}
        <tr id="reservation-table-header-month">
            <td class="text-center"></td>
            {% for header in grid.monthHeaders %}
                <td class="text-center p-1" colspan="{{ header.colspan * 2 }}">{{ getLocalizedMonth(header.label, 'MMM', app.request.locale) }}</td>
            {% endfor %}
        </tr>
        {% endif %}

        {# ── Week headers ── #}
        {% if displayWeek %}
        <tr id="reservation-table-header-week">
            <td class="text-center"></td>
            {% for header in grid.weekHeaders %}
                <td class="text-center p-1" colspan="{{ header.colspan * 2 }}">{{ 'reservation.table.calendarweek'|trans }} {{ header.label }}</td>
            {% endfor %}
        </tr>
        {% endif %}

        {# ── Weekday headers ── #}
        {% if displayWeekday %}
        <tr id="reservation-table-header-weekday" class="table-weekdays">
            <th class="text-center"></th>
            {% for col in grid.dayColumns %}
                {% set weekendCss = col.isWeekend ? ' reservation-table-weekend' : '' %}
                {% set publicdays = getPublicdaysForDay(col.date|date_modify('+0 day'), showCountry, app.request.locale) %}
                {% set holidayText = "" %}
                {% for holiday in publicdays %}
                    {% set holidayText = holidayText ~ holiday.name %}
                    {% if not loop.last %}{% set holidayText = holidayText ~ "<br />" %}{% endif %}
                {% endfor %}
                {% set holidayCss = holidayText|length > 0 ? " bg-info bg-opacity-25 holiday-info" : "" %}
                <th class="text-center{{ weekendCss }}{{ holidayCss }}" colspan="2"
                    {% if holidayText|length > 0 %}
                        data-bs-container="body" data-bs-toggle="popover" data-bs-placement="top"
                        data-bs-content="{{ holidayText }}" data-bs-trigger="hover" data-bs-html="true"
                    {% endif %}
                >{{ weekdayLabels[col.isoDayOfWeek] ?? '' }}</th>
            {% endfor %}
        </tr>
        {% endif %}

        {# ── Day number headers ── #}
        <tr class="table-days">
            <th class="text-center">{{ 'reservation.appartment.name'|trans }}</th>
            {% for col in grid.dayColumns %}
                {% set weekendCss = col.isWeekend ? ' reservation-table-weekend' : '' %}
                {% set publicdays = getPublicdaysForDay(col.date|date_modify('+0 day'), showCountry, app.request.locale) %}
                {% set holidayText = "" %}
                {% for holiday in publicdays %}
                    {% set holidayText = holidayText ~ holiday.name %}
                    {% if not loop.last %}{% set holidayText = holidayText ~ "<br />" %}{% endif %}
                {% endfor %}
                {% set holidayCss = holidayText|length > 0 ? " bg-info bg-opacity-25 holiday-info" : "" %}
                <th class="text-center{{ weekendCss }}{{ holidayCss }}" colspan="2"
                    {% if holidayText|length > 0 %}
                        data-bs-container="body" data-bs-toggle="popover" data-bs-placement="top"
                        data-bs-content="{{ holidayText }}" data-bs-trigger="hover" data-bs-html="true"
                    {% endif %}
                >{{ '%02d'|format(col.dayOfMonth) }}</th>
            {% endfor %}
        </tr>
        </thead>

        <tbody>
        {% set totalColumnCount = grid.dayColumns|length * 2 + 1 %}
        {% set emptyTdNr = 0 %}

        {% for row in grid.rows %}
            {# Subsidiary group header #}
            {% if not row.isSubRow and grid.subsidiaryBreaks[row.apartment.id] is defined %}
                <tr>
                    <td colspan="{{ totalColumnCount }}" class="fw-semibold">
                        {{ grid.subsidiaryBreaks[row.apartment.id] ?? '' }}
                    </td>
                </tr>
            {% endif %}

            {# Room info for first row of each apartment #}
            {% if not row.isSubRow %}
                {% set roomInfo = 'appartment.bedsmax'|trans ~ ": " ~ row.apartment.bedsMax %}
                {% if row.apartment.multipleOccupancy %}
                    {% set roomInfo = roomInfo ~ ' <i class="fa-solid fa-users" title="' ~ 'apartment.multiple.occupancy.text'|trans ~ '"></i>' %}
                {% endif %}
            {% endif %}

            <tr{% if row.isSubRow %} class="border-top-0"{% endif %}>
                {% if row.isSubRow %}
                    <td></td>
                {% else %}
                    <td class="text-center room-info"
                        data-bs-container="body" data-bs-toggle="popover" data-bs-placement="right"
                        data-bs-content="{{ roomInfo }}" data-bs-trigger="hover"
                    >{{ row.apartment.number }}{% if row.apartment.roomCategory is not null and row.apartment.roomCategory.acronym|length > 0 %} ({{ row.apartment.roomCategory.acronym }}){% endif %}</td>
                {% endif %}

                {# ── Cells ── #}
                {% for cell in row.cells %}
                    {% if cell.type == 'reservation' %}
                        {# Reservation cell #}
                        {% set reservation = cell.reservation %}
                        <td class="reservation text-center cell-{{ cell.position }}{{ cell.startsAtDayBoundary ? ' day-start' : '' }}"
                            colspan="{{ cell.span }}"
                        >
                            <div data-action="click->reservations#openReservationAction"
                                 data-reservation-id="{{ cell.reservationId }}"
                                 data-url="{{ path('reservations.get.reservation', {'id': cell.reservationId}) }}"
                                 style="background-color: {{ cell.color }}; color: {{ cell.contrastColor }}"
                                 class="reservation-inner text-center"
                                 title="{{ block('popTitle') }}"
                                 data-bs-content="{{ block('popBody') }}"
                            >{{ cell.displayName }}</div>
                        </td>
                    {% elseif cell.type == 'blocked' %}
                        {# Blocked cell #}
                        <td class="td-blocked" colspan="{{ cell.span }}">
                            <div class="blocked-inner"></div>
                        </td>
                    {% else %}
                        {# Empty half-day cell #}
                        <td class="td-empty td-half td-half-{{ cell.side }}{{ cell.startsAtDayBoundary ? ' day-start' : '' }}"
                            data-day="{{ cell.date }}" data-appartment="{{ row.apartment.id }}"
                            data-tdnumber="{{ emptyTdNr }}"
                        ></td>
                        {% set emptyTdNr = emptyTdNr + 1 %}
                    {% endif %}
                {% endfor %}
            </tr>
        {% endfor %}
        </tbody>
    </table>
</div>
