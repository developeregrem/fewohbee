<div class="container mt-3">
    {# ── DATEV batch-export warnings (single month) ── #}
    {% for warningStr in app.flashes('datev_warnings') %}
        <div class="row">
            <div class="col">
                <div class="alert alert-warning alert-dismissible fade show" role="alert">
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    <p class="mb-2">{{ 'accounting.journal.export.warn_intro'|trans }}</p>
                    <ul class="mb-2">
                        {% for warning in warningStr|split('||') %}
                            <li>{{ warning }}</li>
                        {% endfor %}
                    </ul>
                    {% if batch is defined %}
                        <div class="text-end">
                            <a href="{{ path('journal.batch.export.datev', {'id': batch.id, 'force': 1}) }}"
                               class="btn btn-sm btn-secondary"
                               data-turbo="false" data-turbo-prefetch="false">
                                <i class="fas fa-download"></i> {{ 'accounting.journal.export.force'|trans }}
                            </a>
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>
    {% endfor %}

    {# ── DATEV year-export warnings ── #}
    {% for warningStr in app.flashes('datev_year_warnings') %}
        {% set parts = warningStr|split('||') %}
        {% set warnYear = parts|first %}
        {% set warnList = parts|slice(1) %}
        <div class="row">
            <div class="col">
                <div class="alert alert-warning alert-dismissible fade show" role="alert">
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    <p class="mb-2">{{ 'accounting.journal.export.warn_intro'|trans }}</p>
                    <ul class="mb-2">
                        {% for warning in warnList %}
                            <li>{{ warning }}</li>
                        {% endfor %}
                    </ul>
                    <div class="text-end">
                        <a href="{{ path('journal.export.year.datev', {'year': warnYear, 'force': 1}) }}"
                           class="btn btn-sm btn-secondary"
                           data-turbo="false" data-turbo-prefetch="false">
                            <i class="fas fa-download"></i> {{ 'accounting.journal.export.force'|trans }}
                        </a>
                    </div>
                </div>
            </div>
        </div>
    {% endfor %}

    {# ── Generic flashes ── #}
    {% for type, flashMessages in app.flashes %}
        {% for flashMessage in flashMessages %}
            <div class="row">
                <div class="col">
                    <div class="alert alert-{{ type }} alert-dismissible fade show" role="alert">
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        {{ flashMessage|trans }}
                    </div>
                </div>
            </div>
        {% endfor %}
    {% endfor %}
</div>
