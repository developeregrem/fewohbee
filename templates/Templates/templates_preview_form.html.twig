{% extends 'base.html.twig' %}

{% block title %}
    {{ parent() }} - {{ 'templates.preview'|trans }}
{% endblock %}

{% block content %}
<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h1 class="h4 mb-0">{{ 'templates.preview'|trans }}</h1>
            <div class="text-muted">{{ template.name }}</div>
        </div>
        <a class="btn btn-secondary" href="{{ path('settings.templates.overview') }}">{{ 'button.back'|trans }}</a>
    </div>

    <div class="row g-3">
        <div class="col-lg-4">
            <div class="accordion" id="previewContextAccordion">
                <div class="accordion-item">
                    <h2 class="accordion-header" id="previewContextHeading">
                        <button class="accordion-button" type="button" data-bs-toggle="collapse"
                                data-bs-target="#previewContextBody" aria-expanded="true"
                                aria-controls="previewContextBody">
                            {{ 'templates.preview.context'|trans }}
                        </button>
                    </h2>
                    <div id="previewContextBody" class="accordion-collapse collapse show"
                         aria-labelledby="previewContextHeading" data-bs-parent="#previewContextAccordion">
                        <div class="accordion-body">
                    {% if provider is null %}
                        <div class="alert alert-warning">{{ 'templates.preview.noprovider'|trans }}</div>
                    {% else %}
                        <form method="post"
                              data-turbo="false"
                              action="{{ path('settings.templates.preview', {'id': template.id}) }}">
                            {% for field in contextDefinition %}
                                {% if field.type == 'date' %}
                                    <div class="mb-3">
                                        <label class="form-label">{{ field.label|trans }}</label>
                                        <input type="date" class="form-control" name="{{ field.name }}"
                                               value="{{ context[field.name]|default('') }}" />
                                    </div>
                                {% elseif field.type == 'select' %}
                                    <div class="mb-3">
                                        <label class="form-label">{{ field.label|trans }}</label>
                                        <select class="form-select" name="{{ field.name }}">
                                            {% for option in field.options|default([]) %}
                                                {% set currentValue = context[field.name]|default('') %}
                                                <option value="{{ option.value }}"{% if option.value == currentValue %} selected{% endif %}>
                                                    {{ option.label|trans }}
                                                </option>
                                            {% endfor %}
                                        </select>
                                    </div>
                                {% elseif field.type == 'checkboxes' %}
                                    <div class="mb-3">
                                        <label class="form-label">{{ field.label|trans }}</label>
                                        {% set selectedValues = context[field.name]|default([]) %}
                                        {% for option in field.options|default([]) %}
                                            {% set isChecked = selectedValues is iterable and option.value in selectedValues %}
                                            <div class="form-check">
                                                <input class="form-check-input" type="checkbox" name="{{ field.name }}[]"
                                                       value="{{ option.value }}" id="{{ field.name }}-{{ loop.index }}"
                                                       {% if isChecked %}checked{% endif %}>
                                                <label class="form-check-label" for="{{ field.name }}-{{ loop.index }}">
                                                    {{ option.label|trans }}
                                                </label>
                                            </div>
                                        {% endfor %}
                                    </div>
                                {% else %}
                                    <div class="mb-3">
                                        <label class="form-label">{{ field.label|trans }}</label>
                                        <input type="text" class="form-control" name="{{ field.name }}"
                                               value="{{ context[field.name]|default('') }}"
                                               placeholder="{{ field.placeholder is defined ? field.placeholder|trans : '' }}" />
                                        {% if field.help is defined %}
                                            <div class="form-text">{{ field.help|trans }}</div>
                                        {% endif %}
                                    </div>
                                {% endif %}
                            {% endfor %}

                            <div class="d-flex gap-2">
                                <button type="submit" class="btn btn-primary">{{ 'templates.preview.render'|trans }}</button>
                                {% if template.templateType is not null and '_PDF' in template.templateType.name %}
                                    <button type="submit"
                                            class="btn btn-outline-primary shadow-none"
                                            formtarget="_blank"
                                            data-turbo="false"
                                            title="{{ 'templates.preview.download_pdf'|trans }}"
                                            aria-label="{{ 'templates.preview.download_pdf'|trans }}"
                                            formaction="{{ path('settings.templates.preview.pdf', {'id': template.id}) }}">
                                        <i class="fas fa-file-pdf" aria-hidden="true"></i>
                                    </button>
                                {% endif %}
                            </div>
                        </form>
                    {% endif %}
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="card position-sticky" style="top: 1.5rem;">
                <div class="card-header">{{ 'templates.preview.result'|trans }}</div>
                <div class="card-body">
                    {% if previewWarning %}
                        <div class="alert alert-warning">
                            {{ previewWarning|trans(previewWarningVars|default({})) }}
                        </div>
                    {% endif %}
                    {% if provider is null %}
                        <div class="text-muted">{{ 'templates.preview.noprovider.help'|trans }}</div>
                    {% elseif previewHtml is empty %}
                        <div class="text-muted">{{ 'templates.preview.empty'|trans }}</div>
                    {% else %}
                        <div class="template-preview">{{ previewHtml|raw }}</div>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
