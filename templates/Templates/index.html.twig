{% extends 'base.html.twig' %}

{% block title %}
    {{ parent() }} -  {{ 'templates.title'|trans }}
{% endblock %}

{% block description %}
    {{ parent() }} -  {{ 'templates.description'|trans }}
{% endblock %}

{% block content %}
<div class="container" data-controller="settings templates">
    <div class="row">
        <div class="col">
            {% if operationsTemplatesMissing %}
                <div class="alert alert-info alert-dismissible fade show d-flex flex-wrap align-items-center gap-2"
                     role="alert"
                     data-templates-target="importNotice">
                    <div>
                        <strong>{{ 'templates.operations.import.title'|trans }}</strong>
                        {{ 'templates.operations.import.text'|trans }}
                    </div>
                    <form method="post" action="{{ path('settings.templates.import.operations') }}" class="ms-auto">
                        <input type="hidden" name="_csrf_token" value="{{ importToken }}">
                        <button type="submit" class="btn btn-secondary btn-sm">
                            {{ 'templates.operations.import.button'|trans }}
                        </button>
                    </form>
                    <button type="button"
                            class="btn-close"
                            data-bs-dismiss="alert"
                            aria-label="{{ 'button.close'|trans }}"
                            data-action="templates#dismissImportNotice">
                    </button>
                </div>
            {% endif %}
            <a class="btn btn-secondary" href="{{ path('settings.templates.new.page') }}">
                <i class="fas fa-plus" aria-hidden="true"></i> {{ 'templates.add'|trans }}
            </a>
        </div>
    </div>
    <div class="row mt-3">
        <div class="col">
            {% set lastTypeId = null %}
            {% for template in templates %}
                {% if lastTypeId != template.templateType.id %}
                    {% if lastTypeId is not null %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                    {% endif %}
                    <div class="card mb-3">
                        <div class="card-header">
                            <i class="fas {{ template.templateType.icon }}" aria-hidden="true"></i>
                            {{ template.templateType.name|trans }}
                        </div>
                        <div class="card-body p-0">
                            <table class="table table-bordered table-hover mb-0" style="table-layout: fixed;">
                                <colgroup>
                                    <col style="width: 70%;">
                                    <col style="width: 15%;">
                                    <col style="width: 15%;">
                                </colgroup>
                                <thead>
                                <tr>
                                    <th>{{ 'templates.name'|trans }}</th>
                                    <th>Default</th>
                                    <th>{{ 'base.action'|trans }}</th>
                                </tr>
                                </thead>
                                <tbody>
                    {% set lastTypeId = template.templateType.id %}
                {% endif %}
                <tr>
                    <td>{{ template.name }}</td>
                    <td class="text-center">
                        {% if template.isDefault %}
                            <i class="fas fa-check text-success" aria-hidden="true"></i>
                        {% endif %}
                    </td>
                    <td>
                        <a href="{{ path('settings.templates.edit.page', {'id': template.id}) }}" title="{{ 'button.edit'|trans }}">
                            <i class="fas fa-edit" aria-hidden="true"></i>
                        </a>
                        {% set id = template.id %}
                        {% set targetUrl = path('settings.templates.delete', {'id': template.id}) %}
                        {% use "common/delete_popover.html.twig" %}
                        <a href="#" title="{{ 'button.delete'|trans }}">
                            <i class="fas fa-trash-alt"
                                data-popover="delete"
                                data-title="{{ 'registrationbook.delete.ask'|trans }}"
                                data-bs-content='{{ block('deletePopoverContent') }}'></i></a>
                    </td>
                </tr>
            {% endfor %}
            {% if lastTypeId is not null %}
                                </tbody>
                            </table>
                        </div>
                    </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
{% endblock %}
