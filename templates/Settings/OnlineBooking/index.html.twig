{% extends 'base.html.twig' %}

{% block title %}
    {{ parent() }} - {{ 'online_booking.settings.page_title'|trans }}
{% endblock %}

{% block description %}
    {{ parent() }} - {{ 'online_booking.settings.page_title'|trans }}
{% endblock %}

{% block content %}
{% set standAloneUrl = absolute_url(path('public.booking')) %}
{% set embedUrl = absolute_url(path('public.booking', {'embed': 1})) %}
{% set iframeCode %}<iframe id="fhb-booking" src="{{ embedUrl }}" style="border:0;width:100%;max-width:960px;min-height:400px;" loading="lazy" title="Online Booking"></iframe>
<script>window.addEventListener("message",function(e){if(e.data&&e.data.type==="fhb-resize"){document.getElementById("fhb-booking").style.height=e.data.height+"px"}});</script>{% endset %}
<div class="container" data-controller="settings online-booking-settings online-booking-restrictions"
     data-online-booking-restrictions-restore-hash-value="online-booking-overrides">
    <div class="row justify-content-center">
        <div class="col-lg-10 col-xl-9">

            {# ── Header ── #}
            <div class="d-flex align-items-center justify-content-between mb-3">
                <div>
                    <h2 class="fs-4 mb-1">
                        <i class="fas fa-globe text-primary me-1"></i>
                        {{ 'online_booking.settings.page_title'|trans }}
                    </h2>
                    <div class="d-flex flex-wrap gap-2">
                        <span class="badge {{ form.vars.value.enabled ? 'bg-success-subtle text-success-emphasis' : 'bg-warning-subtle text-warning-emphasis' }}">
                            <i class="fas {{ form.vars.value.enabled ? 'fa-toggle-on' : 'fa-toggle-off' }} me-1"></i>
                            {{ form.vars.value.enabled ? ('online_booking.settings.status_enabled'|trans) : ('online_booking.settings.status_disabled'|trans) }}
                        </span>
                    </div>
                </div>
            </div>

            {# ── restriction override warning ── #}
            {% if restrictionOverrideWarning %}
                <div class="alert alert-warning mb-3 small" role="alert">
                    <i class="fas fa-triangle-exclamation me-1"></i>
                    {{ 'online_booking.settings.restriction_override_warning'|trans }}
                </div>
            {% endif %}

            {{ form_start(form) }}

            {% if form.vars.submitted and not form.vars.valid %}
                <div class="alert alert-danger mb-3" role="alert">
                    <div class="fw-semibold mb-1">{{ 'online_booking.settings.form_invalid_title'|trans }}</div>
                    <div class="small mb-2">{{ 'online_booking.settings.form_invalid_hint'|trans }}</div>
                    <div class="small">
                        {{ form_errors(form.enabled) }}
                        {{ form_errors(form.confirmationEmailTemplateId) }}
                        {{ form_errors(form.inquiryReservationStatusId) }}
                        {{ form_errors(form.bookingReservationStatusId) }}
                        {{ form_errors(form.reservationOriginId) }}
                    </div>
                </div>
            {% endif %}

            {# ── General ── #}
            <div class="card mb-3">
                <div class="card-header">
                    <h5 class="card-title fs-6 mb-0"><i class="fas fa-sliders text-primary me-2"></i>{{ 'online_booking.settings.section_general'|trans }}</h5>
                    <p class="text-body-secondary small mb-0 mt-1">{{ 'online_booking.settings.section_general_desc'|trans }}</p>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">{{ form_row(form.enabled) }}</div>
                        <div class="col-md-6">{{ form_row(form.bookingMode) }}</div>
                    </div>
                    <div class="row mt-2">
                        <div class="col-md-6">{{ form_row(form.bookingHorizonMonths) }}</div>
                    </div>
                </div>
            </div>

            {# ── Availability Scope ── #}
            <div class="card mb-3">
                <div class="card-header">
                    <h5 class="card-title fs-6 mb-0"><i class="fas fa-bed text-primary me-2"></i>{{ 'online_booking.settings.section_availability_scope'|trans }}</h5>
                    <p class="text-body-secondary small mb-0 mt-1">{{ 'online_booking.settings.section_availability_scope_desc'|trans }}</p>
                </div>
                <div class="card-body">
                    {{ form_row(form.subsidiariesMode) }}

                    <div class="border rounded mt-2" data-online-booking-settings-target="subsidiariesWrap">
                        <div class="px-3 py-2 bg-body-secondary border-bottom d-flex justify-content-between align-items-center">
                            <div>
                                <p class="fw-semibold small mb-0">{{ 'online_booking.settings.selected_subsidiaries'|trans }}</p>
                                <p class="text-body-secondary small mb-0">{{ 'online_booking.settings.selected_subsidiaries_hint'|trans }}</p>
                            </div>
                            <span class="badge text-bg-primary" data-online-booking-settings-target="subsidiariesCount"></span>
                        </div>
                        <div class="p-3 row row-cols-1 row-cols-sm-2 row-cols-lg-3 g-2" style="max-height:18rem;overflow:auto">
                            {{ form_widget(form.selectedSubsidiaryIds) }}
                        </div>
                        <div class="px-3 pb-2">
                            {{ form_errors(form.selectedSubsidiaryIds) }}
                        </div>
                    </div>

                    <hr class="my-3">
                    {{ form_row(form.roomsMode) }}

                    <div class="border rounded mt-2" data-online-booking-settings-target="roomsWrap">
                        <div class="px-3 py-2 bg-body-secondary border-bottom d-flex justify-content-between align-items-center">
                            <div>
                                <p class="fw-semibold small mb-0">{{ 'online_booking.settings.selected_rooms'|trans }}</p>
                                <p class="text-body-secondary small mb-0">{{ 'online_booking.settings.selected_rooms_hint'|trans }}</p>
                            </div>
                            <span class="badge text-bg-primary" data-online-booking-settings-target="roomsCount"></span>
                        </div>
                        <div class="p-3 row row-cols-1 row-cols-sm-2 row-cols-lg-3 g-2" style="max-height:18rem;overflow:auto">
                            {{ form_widget(form.selectedRoomIds) }}
                        </div>
                        <div class="px-3 pb-2">
                            {{ form_errors(form.selectedRoomIds) }}
                        </div>
                    </div>
                    {# ── Price overview ── #}
                    {% if reservationOriginConfigured %}
                        <div class="border rounded mt-3">
                            <div class="px-3 py-2 bg-body-secondary border-bottom">
                                <p class="fw-semibold small mb-0"><i class="fas fa-tags me-1"></i>{{ 'online_booking.settings.price_overview_title'|trans }}</p>
                                <p class="text-body-secondary small mb-0">{{ 'online_booking.settings.price_overview_hint'|trans }}</p>
                            </div>
                            <div class="px-3 py-2">
                                <div class="small fw-semibold mb-1">{{ 'online_booking.settings.price_overview_room'|trans }}</div>
                                {% if priceOverview.room is not empty %}
                                    <div class="d-flex flex-wrap gap-1 mb-2">
                                        {% for price in priceOverview.room %}
                                            <span class="badge bg-primary-subtle text-primary-emphasis">{{ price.description }}{% if price.numberOfPersons %} ({{ price.numberOfPersons }}P){% endif %}</span>
                                        {% endfor %}
                                    </div>
                                {% else %}
                                    <p class="text-body-secondary small mb-2"><i class="fas fa-triangle-exclamation text-warning me-1"></i>{{ 'online_booking.settings.price_overview_none'|trans }}</p>
                                {% endif %}

                                <div class="small fw-semibold mb-1">{{ 'online_booking.settings.price_overview_extras'|trans }}</div>
                                {% if priceOverview.extras is not empty %}
                                    <div class="d-flex flex-wrap gap-1 mb-0">
                                        {% for price in priceOverview.extras %}
                                            <span class="badge bg-success-subtle text-success-emphasis">{{ price.description }}</span>
                                        {% endfor %}
                                    </div>
                                {% else %}
                                    <p class="text-body-secondary small mb-0">{{ 'online_booking.settings.price_overview_no_extras'|trans }}</p>
                                {% endif %}
                            </div>
                        </div>
                    {% else %}
                        <div class="alert alert-info mt-3 small" role="alert">
                            <i class="fas fa-info-circle me-1"></i>
                            {{ 'online_booking.settings.price_coverage_hint'|trans|raw }}
                        </div>
                    {% endif %}
                </div>
            </div>

            {# ── Theme ── #}
            <div class="card mb-3">
                <div class="card-header">
                    <h5 class="card-title fs-6 mb-0"><i class="fas fa-palette text-primary me-2"></i>{{ 'online_booking.settings.section_theme'|trans }}</h5>
                    <p class="text-body-secondary small mb-0 mt-1">{{ 'online_booking.settings.section_theme_desc'|trans }}</p>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">{{ form_row(form.themePrimaryColor) }}</div>
                        <div class="col-md-6">{{ form_row(form.themeBackgroundColor) }}</div>
                    </div>
                    <div class="mt-2">
                        <a class="small text-body-secondary text-decoration-none" data-bs-toggle="collapse" href="#customCssCollapse" role="button" aria-expanded="{{ form.vars.value.customCss ? 'true' : 'false' }}" aria-controls="customCssCollapse">
                            <i class="fas fa-chevron-right me-1"></i>{{ 'online_booking.settings.custom_css'|trans }}
                        </a>
                        <div class="collapse{{ form.vars.value.customCss ? ' show' : '' }}" id="customCssCollapse">
                            <div class="mt-2">
                                {{ form_row(form.customCss) }}
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            {# ── Templates & Status ── #}
            <div class="card mb-3">
                <div class="card-header">
                    <h5 class="card-title fs-6 mb-0"><i class="fas fa-envelope-open-text text-primary me-2"></i>{{ 'online_booking.settings.section_templates_status'|trans }}</h5>
                    <p class="text-body-secondary small mb-0 mt-1">{{ 'online_booking.settings.section_templates_status_desc'|trans }}</p>
                </div>
                <div class="card-body">
                    {{ form_row(form.confirmationEmailTemplateId) }}
                    <div class="row">
                        <div class="col-md-6">{{ form_row(form.inquiryReservationStatusId) }}</div>
                        <div class="col-md-6">{{ form_row(form.bookingReservationStatusId) }}</div>
                    </div>
                    {{ form_row(form.reservationOriginId) }}
                </div>
            </div>

            {# ── Checkout Texts ── #}
            <div class="card mb-3">
                <div class="card-header">
                    <h5 class="card-title fs-6 mb-0"><i class="fas fa-file-contract text-primary me-2"></i>{{ 'online_booking.settings.section_booking_texts'|trans }}</h5>
                    <p class="text-body-secondary small mb-0 mt-1">{{ 'online_booking.settings.section_booking_texts_desc'|trans }}</p>
                </div>
                <div class="card-body">
                    {{ form_row(form.paymentTerms) }}
                    {{ form_row(form.cancellationTerms) }}
                    {{ form_row(form.successMessageText) }}
                </div>
            </div>

            {# ── Save bar ── #}
            <div class="card sticky-bottom mb-3" style="z-index:10">
                <div class="card-body py-2 d-flex align-items-center justify-content-between">
                    <p class="text-body-secondary small mb-0 d-none d-md-block">{{ 'online_booking.settings.save_hint'|trans }}</p>
                    <button class="btn btn-primary" type="submit">
                        <i class="fas fa-save me-1"></i>{{ 'online_booking.settings.save'|trans }}
                    </button>
                </div>
            </div>

            {{ form_end(form) }}

            {# ── Category Restrictions ── #}
            {% if categories|length > 0 %}
            <div class="card mb-3">
                <div class="card-header">
                    <h5 class="card-title fs-6 mb-0"><i class="fas fa-shield-halved text-primary me-2"></i>{{ 'online_booking.settings.section_restrictions'|trans }}</h5>
                    <p class="text-body-secondary small mb-0 mt-1">{{ 'online_booking.settings.section_restrictions_desc'|trans }}</p>
                </div>
                <div class="card-body p-0">
                    <form method="post" action="{{ path('settings.online_booking.save_category_restrictions') }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('ob_category_restrictions') }}">
                        <div class="table-responsive">
                            <table class="table table-sm table-hover align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th class="ps-3">{{ 'online_booking.settings.restriction_category'|trans }}</th>
                                        <th class="text-center" style="width:140px">{{ 'online_booking.settings.restriction_min_weekday'|trans }}</th>
                                        <th class="text-center" style="width:140px">{{ 'online_booking.settings.restriction_min_weekend'|trans }}</th>
                                        <th class="text-center" style="width:140px">{{ 'online_booking.settings.restriction_max_rooms'|trans }}</th>
                                        <th class="text-center" style="width:140px">{{ 'online_booking.settings.restriction_min_occupancy'|trans }}</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for category in categories %}
                                        {% set catId = category.id %}
                                        {% set minStay = minStayByCategory[catId] ?? null %}
                                        {% set limit = limitsByCategory[catId] ?? null %}
                                        <tr>
                                            <td class="ps-3 fw-semibold small">{{ category.name }}</td>
                                            <td class="text-center">
                                                <input type="number" name="min_weekday_{{ catId }}" class="form-control form-control-sm text-center mx-auto" style="width:80px"
                                                    value="{{ minStay ? minStay.minNightsWeekday : '' }}" min="1" max="365"
                                                    placeholder="-">
                                            </td>
                                            <td class="text-center">
                                                <input type="number" name="min_weekend_{{ catId }}" class="form-control form-control-sm text-center mx-auto" style="width:80px"
                                                    value="{{ minStay ? minStay.minNightsWeekend : '' }}" min="1" max="365"
                                                    placeholder="-">
                                            </td>
                                            <td class="text-center">
                                                <input type="number" name="max_rooms_{{ catId }}" class="form-control form-control-sm text-center mx-auto" style="width:80px"
                                                    value="{{ limit ? limit.maxRooms : '' }}" min="1" max="999"
                                                    placeholder="-">
                                            </td>
                                            <td class="text-center">
                                                <input type="number" name="min_occupancy_{{ catId }}" class="form-control form-control-sm text-center mx-auto" style="width:80px"
                                                    value="{{ limit ? limit.minOccupancy : '' }}" min="1" max="99"
                                                    placeholder="-">
                                            </td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                        <div class="card-body py-2 border-top d-flex justify-content-end">
                            <button class="btn btn-sm btn-primary" type="submit">
                                <i class="fas fa-save me-1"></i>{{ 'online_booking.settings.restrictions_save'|trans }}
                            </button>
                        </div>
                    </form>
                </div>
            </div>
            {% endif %}

            {# ── Special Periods (Min Stay Overrides) ── #}
            <div class="card mb-3" id="online-booking-overrides">
                <div class="card-header d-flex align-items-center justify-content-between">
                    <div>
                        <h5 class="card-title fs-6 mb-0"><i class="fas fa-calendar-alt text-primary me-2"></i>{{ 'online_booking.settings.section_overrides'|trans }}</h5>
                        <p class="text-body-secondary small mb-0 mt-1">{{ 'online_booking.settings.section_overrides_desc'|trans }}</p>
                    </div>
                    <button class="btn btn-sm btn-outline-primary" type="button" data-bs-toggle="offcanvas" data-bs-target="#overrideOffcanvas">
                        <i class="fas fa-plus me-1"></i>{{ 'online_booking.settings.override_add'|trans }}
                    </button>
                </div>
                <div class="card-body p-0">
                    {% if overrides|length > 0 %}
                        <div class="table-responsive" data-online-booking-restrictions-target="overridesTable">
                            <table class="table table-sm table-hover align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th class="ps-3">{{ 'online_booking.settings.override_period'|trans }}</th>
                                        <th>{{ 'online_booking.settings.override_category'|trans }}</th>
                                        <th class="text-center" style="width:120px">{{ 'online_booking.settings.override_min_nights'|trans }}</th>
                                        <th class="text-end pe-3" style="width:100px"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for override in overrides %}
                                        <tr>
                                            <td class="ps-3 small">
                                                {{ override.startDate|date('d.m.Y') }} – {{ override.endDate|date('d.m.Y') }}
                                            </td>
                                            <td class="small">
                                                {{ override.roomCategory ? override.roomCategory.name : ('online_booking.settings.override_all_categories'|trans) }}
                                            </td>
                                            <td class="text-center fw-semibold">{{ override.minNights }}</td>
                                            <td class="text-end pe-3">
                                                <button type="button" class="btn btn-sm btn-outline-secondary me-1"
                                                    data-bs-toggle="offcanvas" data-bs-target="#overrideOffcanvas"
                                                    data-override-id="{{ override.id }}"
                                                    data-override-start="{{ override.startDate|date('Y-m-d') }}"
                                                    data-override-end="{{ override.endDate|date('Y-m-d') }}"
                                                    data-override-nights="{{ override.minNights }}"
                                                    data-override-category="{{ override.roomCategory ? override.roomCategory.id : '' }}"
                                                    data-action="click->online-booking-restrictions#editOverride">
                                                    <i class="fas fa-pen-to-square"></i>
                                                </button>
                                                {% set id = override.id %}
                                                {% set targetUrl = path('settings.online_booking.delete_override', {'id': override.id}) %}
                                                {% set deletePopoverHint = 'online_booking.settings.override_confirm_delete'|trans %}
                                                {% use "common/delete_popover.html.twig" %}
                                                <button type="button"
                                                        class="btn btn-sm btn-link text-danger p-0 border-0 align-baseline"
                                                        title="{{ 'button.delete'|trans }}"
                                                        data-popover="delete"
                                                        data-title="{{ 'registrationbook.delete.ask'|trans }}"
                                                        data-bs-content='{{ block('deletePopoverContent') }}'>
                                                    <i class="fas fa-trash"></i>
                                                </button>
                                            </td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    {% else %}
                        <div class="p-3 text-body-secondary small text-center d-none" data-online-booking-restrictions-target="overridesTable"></div>
                        <div class="p-3 text-body-secondary small text-center" data-online-booking-restrictions-target="overridesEmpty">
                            {{ 'online_booking.settings.override_none'|trans }}
                        </div>
                    {% endif %}
                    {% if overrides|length > 0 %}
                        <div class="p-3 text-body-secondary small text-center d-none" data-online-booking-restrictions-target="overridesEmpty">
                            {{ 'online_booking.settings.override_none'|trans }}
                        </div>
                    {% endif %}
                </div>
            </div>

            {# ── Override Offcanvas ── #}
            <div class="offcanvas offcanvas-end" tabindex="-1" id="overrideOffcanvas">
                <div class="offcanvas-header">
                    <h5 class="offcanvas-title" id="overrideOffcanvasLabel">{{ 'online_booking.settings.override_add'|trans }}</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
                </div>
                <div class="offcanvas-body">
                    <form method="post" action="{{ path('settings.online_booking.save_override') }}"
                          data-action="submit->online-booking-restrictions#rememberScrollTarget">
                        <input type="hidden" name="_token" value="{{ csrf_token('ob_override') }}">
                        <input type="hidden" name="override_id" value="" data-online-booking-restrictions-target="overrideId">

                        <div class="mb-3">
                            <label class="form-label small fw-semibold">{{ 'online_booking.settings.override_start_date'|trans }}</label>
                            <input type="date" name="start_date" class="form-control" required data-online-booking-restrictions-target="startDate">
                        </div>

                        <div class="mb-3">
                            <label class="form-label small fw-semibold">{{ 'online_booking.settings.override_end_date'|trans }}</label>
                            <input type="date" name="end_date" class="form-control" required data-online-booking-restrictions-target="endDate">
                        </div>

                        <div class="mb-3">
                            <label class="form-label small fw-semibold">{{ 'online_booking.settings.override_min_nights'|trans }}</label>
                            <input type="number" name="min_nights" class="form-control" min="1" max="365" value="1" required data-online-booking-restrictions-target="minNights">
                        </div>

                        <div class="mb-3">
                            <label class="form-label small fw-semibold">{{ 'online_booking.settings.override_category'|trans }}</label>
                            <div class="border rounded p-2" style="max-height:12rem;overflow:auto" data-online-booking-restrictions-target="categoryList">
                                <div class="form-check mb-1">
                                    <input class="form-check-input" type="checkbox" name="room_category_ids[]" value="" id="overrideCatAll"
                                        data-online-booking-restrictions-target="categoryAll"
                                        data-action="change->online-booking-restrictions#toggleAll" checked>
                                    <label class="form-check-label small" for="overrideCatAll">{{ 'online_booking.settings.override_all_categories'|trans }}</label>
                                </div>
                                <hr class="my-1">
                                {% for category in categories %}
                                    <div class="form-check mb-1">
                                        <input class="form-check-input" type="checkbox" name="room_category_ids[]" value="{{ category.id }}" id="overrideCat{{ category.id }}"
                                            data-online-booking-restrictions-target="categoryItem"
                                            data-action="change->online-booking-restrictions#toggleItem">
                                        <label class="form-check-label small" for="overrideCat{{ category.id }}">{{ category.name }}</label>
                                    </div>
                                {% endfor %}
                            </div>
                        </div>

                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-save me-1"></i>{{ 'online_booking.settings.override_save'|trans }}
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            {# ── Embed ── #}
            <div class="card mb-3">
                <div class="card-header">
                    <h5 class="card-title fs-6 mb-0"><i class="fas fa-code text-primary me-2"></i>{{ 'online_booking.settings.section_embed'|trans }}</h5>
                    <p class="text-body-secondary small mb-0 mt-1">{{ 'online_booking.settings.section_embed_desc'|trans }}</p>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">{{ 'online_booking.settings.embed_url_label'|trans }}</label>
                        <div class="input-group" data-controller="copy" data-copy-hint-value="{{ 'copy.sucess'|trans }}">
                            <input type="text" readonly class="form-control font-monospace small" value="{{ standAloneUrl }}" data-copy-target="input">
                            <button class="btn btn-outline-secondary shadow-none" type="button" data-action="click->copy#copy" title="{{ 'copy.text'|trans }}">
                                <i class="fas fa-copy"></i>
                            </button>
                        </div>
                    </div>

                    <div>
                        <label class="form-label small fw-semibold">{{ 'online_booking.settings.embed_iframe_label'|trans }}</label>
                        <div data-controller="copy" data-copy-hint-value="{{ 'copy.sucess'|trans }}">
                            <textarea readonly class="form-control font-monospace small mb-2" rows="5" style="white-space:pre;resize:vertical" data-copy-target="input">{{ iframeCode }}</textarea>
                            <button class="btn btn-outline-secondary ms-auto" type="button" data-action="click->copy#copy">
                                <i class="fas fa-copy me-1"></i>{{ 'copy.text'|trans }}
                            </button>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>
{% endblock %}
